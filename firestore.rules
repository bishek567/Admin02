rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidClient(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'phone', 'bookingsCount', 'totalSpent', 'status', 'joinedDate'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.email is string && data.email.size() <= 200
        && data.phone is string && data.phone.size() <= 50
        && data.bookingsCount is int && data.bookingsCount >= 0
        && (data.totalSpent is float || data.totalSpent is int) && data.totalSpent >= 0
        && (data.status == 'Active' || data.status == 'Suspended')
        && data.joinedDate is string && data.joinedDate.size() <= 50;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['id', 'clientName', 'clientEmail', 'serviceName', 'date', 'time', 'therapist', 'price', 'status', 'paymentStatus', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.clientName is string && data.clientName.size() <= 200
        && data.clientEmail is string && data.clientEmail.size() <= 200
        && data.serviceName is string && data.serviceName.size() <= 200
        && data.date is string && data.date.size() <= 50
        && data.time is string && data.time.size() <= 50
        && data.therapist is string && data.therapist.size() <= 100
        && (data.price is float || data.price is int) && data.price >= 0
        && (data.status == 'Pending' || data.status == 'Confirmed' || data.status == 'Completed' || data.status == 'Cancelled')
        && (data.paymentStatus == 'Paid' || data.paymentStatus == 'Pending' || data.paymentStatus == 'Refunded')
        && data.createdAt is string && data.createdAt.size() <= 100;
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['id', 'bookingId', 'clientName', 'serviceName', 'date', 'amount', 'method', 'status', 'invoiceNumber'])
        && data.id is string && data.id.size() <= 128
        && data.bookingId is string && data.bookingId.size() <= 128
        && data.clientName is string && data.clientName.size() <= 200
        && data.serviceName is string && data.serviceName.size() <= 200
        && data.date is string && data.date.size() <= 50
        && (data.amount is float || data.amount is int) && data.amount >= 0
        && (data.method == 'Card' || data.method == 'Apple Pay' || data.method == 'Cash' || data.method == 'Bank Transfer')
        && (data.status == 'Paid' || data.status == 'Pending' || data.status == 'Refunded')
        && data.invoiceNumber is string && data.invoiceNumber.size() <= 100;
    }

    function isValidCoupon(data) {
      return data.keys().hasAll(['id', 'code', 'discountType', 'discountValue', 'maxUses', 'usedCount', 'expiryDate', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.code is string && data.code.size() <= 50
        && (data.discountType == 'percentage' || data.discountType == 'fixed')
        && (data.discountValue is float || data.discountValue is int) && data.discountValue >= 0
        && data.maxUses is int && data.maxUses >= 0
        && data.usedCount is int && data.usedCount >= 0
        && data.expiryDate is string && data.expiryDate.size() <= 50
        && (data.status == 'Active' || data.status == 'Expired');
    }

    function isValidReview(data) {
      return data.keys().hasAll(['id', 'clientName', 'serviceName', 'rating', 'comment', 'date', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.clientName is string && data.clientName.size() <= 200
        && data.serviceName is string && data.serviceName.size() <= 200
        && data.rating is int && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 5000
        && data.date is string && data.date.size() <= 50
        && (data.status == 'Published' || data.status == 'Hidden');
    }

    // --- Collections ---

    // 1. Clients collection
    match /clients/{clientId} {
      allow read: if true; // Any authenticated personnel or public lookup for booking
      allow create: if isValidId(clientId) && isValidClient(incoming());
      allow update: if isValidId(clientId) && isValidClient(incoming());
      allow delete: if isValidId(clientId);
    }

    // 2. Bookings collection
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if isValidId(bookingId) && isValidBooking(incoming());
      allow update: if isValidId(bookingId) && isValidBooking(incoming());
      allow delete: if isValidId(bookingId);
    }

    // 3. Payments collection
    match /payments/{paymentId} {
      allow read: if true;
      allow create: if isValidId(paymentId) && isValidPayment(incoming());
      allow update: if isValidId(paymentId) && isValidPayment(incoming());
      allow delete: if isValidId(paymentId);
    }

    // 4. Coupons collection
    match /coupons/{couponId} {
      allow read: if true;
      allow create: if isValidId(couponId) && isValidCoupon(incoming());
      allow update: if isValidId(couponId) && isValidCoupon(incoming());
      allow delete: if isValidId(couponId);
    }

    // 5. Reviews collection
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidId(reviewId) && isValidReview(incoming());
      allow update: if isValidId(reviewId) && isValidReview(incoming());
      allow delete: if isValidId(reviewId);
    }
  }
}
